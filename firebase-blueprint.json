{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings and status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "settings": {
          "type": "object",
          "properties": {
            "voiceSpeed": { "type": "number" },
            "voicePitch": { "type": "number" },
            "theme": { "type": "string" },
            "accentColor": { "type": "string" },
            "autoListen": { "type": "boolean" },
            "autoListenSensitivity": { "type": "number" },
            "hapticFeedback": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "User specific tasks or reminders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "value": { "type": "string" },
        "time": { "type": "number" },
        "remaining": { "type": "number" },
        "dueAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "value", "time"]
    },
    "SystemConfig": {
      "title": "System Config",
      "description": "Global system settings",
      "type": "object",
      "properties": {
        "broadcast": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Memory trace in the neural link",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User settings and metadata"
    },
    "users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Tasks belonging to the user"
    },
    "users/{userId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Synaptic memories of the neural link"
    },
    "system/config": {
      "schema": "SystemConfig",
      "description": "Global application configuration"
    }
  }
}
