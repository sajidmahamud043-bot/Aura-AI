rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Admin lookup helper
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'sajidmahamud043@gmail.com' || 
              exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }

    // Validation Blueprints
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['user', 'admin'] &&
             data.uid is string &&
             data.email is string;
    }

    function isValidTask(data) {
      return data.keys().hasAll(['id', 'userId', 'type', 'value', 'time']) &&
             data.userId == request.auth.uid &&
             data.id is string &&
             data.value is string &&
             data.value.size() <= 1000 &&
             (!data.keys().contains('dueAt') || data.dueAt is string);
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['role', 'text', 'timestamp']) &&
             data.role in ['user', 'model'] &&
             data.text is string &&
             data.text.size() <= 4000;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isEmailVerified() && userId == request.auth.uid && isValidUserProfile(incoming()) && (
        incoming().role == 'user' || 
        (incoming().role == 'admin' && request.auth.token.email == 'sajidmahamud043@gmail.com')
      );
      
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && (
        // User updating their own profile (cannot change role)
        (userId == request.auth.uid && incoming().role == existing().role && incoming().uid == existing().uid && isValidUserProfile(incoming())) ||
        // Admin updating
        isAdmin()
      );
      
      allow delete: if isAdmin();

      // 2. Tasks Subcollection
      match /tasks/{taskId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        
        allow create: if isEmailVerified() && userId == request.auth.uid && isValidTask(incoming()) && isValidId(taskId);
        
        allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) && 
                         incoming().userId == existing().userId && isValidTask(incoming());
        
        allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }

      // 3. Messages Subcollection
      match /messages/{messageId} {
        allow list: if isSignedIn() && userId == request.auth.uid;
        allow get: if isSignedIn() && userId == request.auth.uid && isValidId(messageId);
        allow create, update: if isSignedIn() && userId == request.auth.uid && 
                               isValidId(messageId) && isValidMessage(incoming());
        allow delete: if isSignedIn() && userId == request.auth.uid && isValidId(messageId);
      }
    }

    // Admin specific collection for bootstrapping or manual adds
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // Global System Configuration
    match /system/config {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Collection Group for Admin Global View
    match /{path=**}/tasks/{taskId} {
      allow read: if isAdmin();
    }
  }
}
